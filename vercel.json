{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    { "src": "backend/main.py", "use": "@vercel/python" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/blog", "destination": "/frontend/blog.html" },
    { "source": "/concursos/(.*)", "destination": "/backend/main.py" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}