{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    { "src": "backend/main.py", "use": "@vercel/python" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/concursos/(.*)", "dest": "backend/main.py" },
    { "src": "/blog", "dest": "frontend/blog.html" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}